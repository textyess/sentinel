# ─────────────────────────────────────────────────────────────────────────────
# Sentinel configuration. Copy to `.env` (gitignored) and fill in.
# Most of these can also be set from the dashboard Settings panel (`pnpm ui`),
# which writes them back here and applies them to the running agent immediately.
# ─────────────────────────────────────────────────────────────────────────────

# Login Sentinel uses to drive the app.
# NOTE: when pointing at PROD, the seeded test users (onboarded-user@textyess.com)
# do NOT exist — you must supply a REAL account here (yours, or a dedicated
# sentinel@textyess.com QA account).
SENTINEL_EMAIL=
SENTINEL_PASSWORD=

# The web app Sentinel drives. Examples:
#   http://localhost:3000          (local web; backend resolved by apps/web/.env)
#   https://app.textyess.com       (deployed prod dashboard — "work in prod")
# Defaults to http://localhost:3000 when unset.
SENTINEL_BASE_URL=http://localhost:3000

# Run the browser headless (true) or visibly (false). Default: true.
# Tip: set false the first time to watch the login happen.
SENTINEL_HEADLESS=true

# Per-step login timeout (ms). Default 45000 — generous because Next.js dev
# compiles the /login route on first hit, which can take 15-40s cold.
SENTINEL_LOGIN_TIMEOUT=45000

# Human-like pacing: randomized "think" pauses before actions + an adaptive
# per-page dwell (scroll + read, longer on content-rich pages). Makes recorded
# runs look like a person using the app. Set false for fast/CI runs.
SENTINEL_HUMAN_PACING=true
SENTINEL_PACE_MS=700              # base think-time between actions (jittered)
SENTINEL_MAX_DWELL_MS=6000        # cap on per-page dwell

# Read-only mode. Mutating requests (POST/PUT/PATCH/DELETE) are aborted at the
# network layer except the auth endpoints needed to log in. Read-only is FORCED
# whenever the target is a remote (non-local) host OR a production datastore is
# detected — regardless of this flag. Set it to false only to allow writes
# against a purely local, non-prod stack.
SENTINEL_READ_ONLY=true

# Escape hatch: the ONLY way to enable writes once a production/remote target is
# detected. Leave false unless you really mean it.
SENTINEL_ALLOW_PROD_WRITES=false

# Where Sentinel writes videos / screenshots / sessions / graphs.
# Defaults to apps/qa-agent/.sentinel
# SENTINEL_OUTPUT_DIR=

# ─── Dashboard (`pnpm ui`: tag Sentinel on a PR → recorded run + verdict) ─────
# Local dashboard address is http://127.0.0.1:<port> (bound to localhost only).
# SENTINEL_UI_PORT=4317
# How often the dashboard polls registered repos for @-mentions (ms). Default 30000.
# SENTINEL_POLL_MS=30000
# Max concurrent verify runs. Keep at 1 — LLM cost/trace state is process-global.
# SENTINEL_MAX_CONCURRENT=1
# Polls to wait for a PR's preview deployment before giving up. Default 10.
# SENTINEL_MAX_PREVIEW_RETRIES=10
#
# Generic (non-TextYess) projects reference their test credentials by ENV VAR NAME
# (entered in the registration form) — the dashboard NEVER stores raw secrets.
# Define the named vars here, e.g. for repo acme/web:
#   SENTINEL_PROJECT_ACME_WEB_EMAIL=
#   SENTINEL_PROJECT_ACME_WEB_PASSWORD=

# ─── LLM reasoning layer (site map, later interaction/verdict) ────────────────
# Provider for the `sitemap` command (and future LLM steps). Vercel AI SDK under
# the hood, so it's provider-swappable.
SENTINEL_LLM_PROVIDER=bedrock           # anthropic | openai | bedrock
# Per-provider default model is used if unset:
#   anthropic -> claude-3-5-sonnet-latest
#   openai    -> gpt-4o
#   bedrock   -> eu.anthropic.claude-sonnet-4-6  (same as brain0)
# SENTINEL_LLM_MODEL=eu.anthropic.claude-sonnet-4-6

# Optional: trace LLM calls + cost to Langfuse (same keys as apps/api/.env).
# Without these, the run still prints a local cost estimate.
# LANGFUSE_SECRET_KEY=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_BASEURL=

# Credentials for your chosen provider (the AI SDK reads these directly):
# bedrock (Claude on AWS Bedrock — same creds as apps/brain0/.env):
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
# anthropic direct:
# ANTHROPIC_API_KEY=
# openai:
# OPENAI_API_KEY=
