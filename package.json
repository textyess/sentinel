{
  "name": "sentinel-qa-agent",
  "version": "0.0.1",
  "license": "MIT",
  "description": "Sentinel — an autonomous, persona-driven browser agent that learns the app and tests PRs with video evidence. Repo-agnostic core + per-repo adapters.",
  "type": "module",
  "scripts": {
    "sentinel": "tsx src/cli.ts",
    "guard": "tsx src/cli.ts guard",
    "login": "tsx src/cli.ts login",
    "smoke": "tsx src/cli.ts smoke",
    "crawl": "tsx src/cli.ts crawl",
    "sitemap": "tsx src/cli.ts sitemap",
    "pr": "tsx src/cli.ts pr",
    "verify": "tsx src/cli.ts verify",
    "dev": "next dev -p ${SENTINEL_UI_PORT:-4317} -H 127.0.0.1",
    "ui": "next dev -p ${SENTINEL_UI_PORT:-4317} -H 127.0.0.1",
    "build": "next build",
    "start": "next start -p ${SENTINEL_UI_PORT:-4317} -H 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src app components hooks lib instrumentation.ts next.config.ts",
    "format": "biome check --write src app components hooks lib instrumentation.ts next.config.ts",
    "clean": "rm -rf .sentinel .turbo .next dist"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^1.1.6",
    "@ai-sdk/anthropic": "^1.2.0",
    "@ai-sdk/openai": "^1.3.6",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@tanstack/react-query": "^5.66.0",
    "ai": "^4.2.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^12.1.0",
    "dotenv": "^17.2.3",
    "langfuse": "^3.38.6",
    "lucide-react": "^0.475.0",
    "next": "^15.1.6",
    "next-themes": "^0.4.4",
    "playwright": "^1.58.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2.0.1",
    "tailwind-merge": "^3.0.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@tailwindcss/postcss": "^4.0.6",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "tailwindcss": "^4.0.6",
    "tw-animate-css": "^1.2.4",
    "tsx": "^4.19.2",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22"
  }
}
